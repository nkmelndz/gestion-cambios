@startuml Arquitectura de Paquetes - GestioCambios

' --- Estilo y Configuración ---
skinparam package {
    BackgroundColor #1c2030
    BorderColor #6c63ff
    FontColor #e8eaf2
    FontSize 13
    BorderThickness 2
}
skinparam arrow {
    Color #6c63ff
    Thickness 1.2
}
skinparam Shadowing false

title Arquitectura de Paquetes (Grid 2x4 - Basado en Planificación)

' --- Fila 1 ---
together {
  package "Autenticación y\nDashboard" as P1 {}
  package "Módulo de\nSolicitudes" as P2 {}
  package "Gestión y\nClasificación" as P3 {}
  package "Análisis de\nImpacto" as P4 {}
}

' --- Fila 2 ---
together {
  package "Módulo de\nAprobación" as P5 {}
  package "Módulo de\nImplementación" as P6 {}
  package "Módulo de\nPruebas y QA" as P7 {}
  package "Despliegue y\nCierre" as P8 {}
}

' --- Alineación Vertical ---
P1 -[hidden]down- P5
P2 -[hidden]down- P6
P3 -[hidden]down- P7
P4 -[hidden]down- P8

' --- Flujo de Dependencias ---
P2 -right-> P3
P3 -right-> P4
P4 -down-> P5
P5 -left-> P6
P6 -left-> P7
P7 -left-> P8
P8 ..> P2 : Cierre

@enduml
